{
  "name": "voces-unidas",
  "private": true,
  "workspaces": [
    "apps/pwa",
    "apps/landing"
  ],
  "scripts": {
    "dev:pwa": "npm -w apps/pwa run dev",
    "build:pwa": "npm -w apps/pwa run build",
    "dev:server": "cd apps/server && go run .",
    "build:server": "cd apps/server && go build -o ../../dist/voces-unidas .",
    "build:all": "npm run build:pwa && npm run build:server"
  }
}
